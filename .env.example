# ============================================================
# FileDrop — infrastructure (docker-compose) env
# Backend has its own .env in ./backend/.env (see backend/.env.example)
# ============================================================

# PostgreSQL
POSTGRES_USER=filedrop
POSTGRES_PASSWORD=filedrop
POSTGRES_DB=filedrop
POSTGRES_PORT=5432

# RustFS (S3-compatible object storage)
RUSTFS_ACCESS_KEY=filedrop
RUSTFS_SECRET_KEY=filedrop-secret
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
