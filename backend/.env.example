# --- Server ---
NODE_ENV=development
PORT=3000

# --- Database ---
DATABASE_URL=postgresql://filedrop:filedrop@127.0.0.1:5432/filedrop

# --- Auth / Session ---
SESSION_TTL_DAYS=14
COOKIE_SECURE=false
COOKIE_DOMAIN=
BCRYPT_ROUNDS=12

# --- Admin bootstrap (optional) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FIRSTNAME=
ADMIN_LASTNAME=

# --- Download token (JWT for password-protected downloads) ---
DOWNLOAD_TOKEN_SECRET=change-me-download-token-secret

# --- Storage (RustFS / S3) ---
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=filedrop
S3_SECRET_KEY=filedrop-secret
S3_BUCKET=filedrop
S3_FORCE_PATH_STYLE=true

# --- Quotas ---
USER_STORAGE_QUOTA_GB=10
MAX_FILE_SIZE_ANON_MB=50
MAX_FILE_SIZE_USER_MB=500
STORAGE_TOTAL_BYTES=107374182400

# --- Frontend ---
FRONTEND_URL=http://localhost:5173

# --- Mail (optional; if blank, links are logged to console) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@filedrop.local
