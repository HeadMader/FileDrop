# --- Server ---
NODE_ENV=development
PORT=3000

# --- Database ---
DATABASE_URL=postgresql://filedrop:filedrop@127.0.0.1:5432/filedrop

# --- Auth / Session ---
SESSION_TTL_DAYS=14
COOKIE_SECURE=false
COOKIE_DOMAIN=
BCRYPT_ROUNDS=12

# --- Admin bootstrap (optional) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FIRSTNAME=
ADMIN_LASTNAME=

# --- Download token (JWT for password-protected downloads) ---
DOWNLOAD_TOKEN_SECRET=change-me-download-token-secret

# --- Storage (RustFS / S3) ---
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=filedrop
S3_SECRET_KEY=filedrop-secret
S3_BUCKET=filedrop
S3_FORCE_PATH_STYLE=true

# --- Quotas ---
USER_STORAGE_QUOTA_GB=10
